{
  "compilerOptions": {
    "target": "ES2023",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "outDir": "./.selfrun-dist",
    "rootDir": ".",
    "strict": true,
    "skipLibCheck": true,
    "rewriteRelativeImportExtensions": true,
    "erasableSyntaxOnly": true,
    "types": ["node"]
  },
  "include": [
    "scripts/core-self-run.ts",
    "src/game/robotSlide/**/*.ts"
  ]
}
